{
  "model": {
    "base_model": "Qwen/Qwen3-0.6B"
  },
  "data": {
    "max_samples": 100
  },
  "sft": {
    "output_dir": "./models/sft_model",
    "num_epochs": 1,
    "batch_size": 2,
    "learning_rate": 5e-05,
    "use_lora": true
  },
  "grpo": {
    "output_dir": "./models/grpo_model",
    "num_epochs": 1,
    "batch_size": 2,
    "learning_rate": 1e-05,
    "num_generations": 4,
    "kl_coef": 0.05,
    "use_lora": true,
    "reward_type": "accuracy"
  },
  "eval": {
    "max_samples": 50
  },
  "monitoring": {
    "use_wandb": false,
    "use_tensorboard": true
  },
  "results_path": "training_results.json"
}